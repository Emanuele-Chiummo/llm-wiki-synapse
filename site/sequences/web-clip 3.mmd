sequenceDiagram
    %% F11 Web Clipper — secure clip ingress (ADR-0038)
    %% Shows: Extension → POST /clip → 4 security gates → atomic write → watcher → ingest_file

    participant Ext as Chrome MV3 Extension
    participant Page as Active Tab (content context)
    participant API as FastAPI POST /clip
    participant Gates as Security Gates (ADR-0038 §2)
    participant FS as vault/raw/sources/
    participant Watch as Watchdog Observer (watcher.py)
    participant Ingest as ingest_file (ADR-0003)

    %% ── Browser-side: extract article ────────────────────────────────────────
    Note over Ext,Page: User clicks "Clip to Synapse" in popup
    Ext->>Page: scripting.executeScript([Readability.js, turndown.js, extractFn])
    Page-->>Ext: {title, markdown, url}

    %% ── POST /clip with bearer token ─────────────────────────────────────────
    Ext->>API: POST /clip  Authorization: Bearer <CLIP_TOKEN>
    Note right of Ext: Origin: chrome-extension://<id>  [auto-set by Chrome]
    Note right of Ext: {url, title, markdown}

    %% ── Gate 1: CLIP_ENABLED ─────────────────────────────────────────────────
    API->>Gates: CLIP_ENABLED check
    alt CLIP_ENABLED=false
        Gates-->>Ext: 503 disabled
    end

    %% ── Gate 2: Token (S-1 fix) ──────────────────────────────────────────────
    Gates->>Gates: hmac.compare_digest(presented, CLIP_TOKEN)  [constant-time]
    alt missing or wrong token
        Gates-->>Ext: 401 Unauthorized
    end

    %% ── Gate 3: Origin allowlist (S-3 fix) ───────────────────────────────────
    Gates->>Gates: origin in (CLIP_ALLOWED_ORIGINS ∪ loopback)?
    Note over Gates: Server-side check BEFORE any disk write
    Note over Gates: CORS alone does NOT block simple POST drive-by writes
    alt Origin not in allowlist
        Gates-->>Ext: 403 Forbidden
    end

    %% ── Gate 4: Body cap (S-5 fix) ───────────────────────────────────────────
    Gates->>Gates: Content-Length ≤ CLIP_MAX_BODY_BYTES?
    Gates->>Gates: accumulated body bytes ≤ CLIP_MAX_BODY_BYTES?  [belt-and-braces]
    alt body too large
        Gates-->>Ext: 413 Request Entity Too Large
    end

    %% ── Gate 5: Safe path (S-2 fix) ─────────────────────────────────────────
    Gates->>Gates: _clip_safe_filename(title, url)   [strips /\\:*?"<>|, clamps 180 chars]
    Gates->>Gates: safe_source_name(filename)         [ADR-0020 §2.2 sanitizer]
    Gates->>Gates: resolve_under_sources(name)        [containment: must be inside raw/sources/]
    Note over Gates: Caller NEVER supplies a base path (S-2 closed)
    alt unsafe filename or traversal
        Gates-->>Ext: 400 Bad Request
    end

    %% ── Atomic write (I5) ────────────────────────────────────────────────────
    API->>FS: mkstemp(dir=raw/sources/) → write content → os.replace(tmp, dst)
    Note over FS: Atomic: crash mid-write cannot corrupt vault (I5)
    Note over FS: YAML frontmatter auto-generated by server (title, type, sources, clip_url)

    %% ── Watcher picks up the file (I1 — no new ingest path) ─────────────────
    FS-->>Watch: inotify CREATE/MODIFY event on raw/sources/<filename>.md
    Watch->>Watch: mtime/SHA gate (ADR-0001)
    alt unchanged content (re-clip of same page)
        Watch->>Watch: status=skipped  [I1 — no double-ingest]
    else new or changed content
        Watch->>Ingest: ingest_file(path)  [ADR-0003 — existing pipeline, no new path]
        Ingest-->>Watch: IngestResult {status, page_id}
    end

    %% ── 202 response ─────────────────────────────────────────────────────────
    API-->>Ext: 202 {file_path, status="queued", overwritten}
    Note right of Ext: Extension shows success: "Saved: raw/sources/Article-Title.md"
