    Container_Boundary(api, "FastAPI service") {
        Component(rest, "REST + provider + graph + ingest/runs + chat + upload + schedule endpoints", "FastAPI routers", "GET/POST /provider/config, POST /ingest/trigger (202), GET /ingest/runs (ADR-0018 §7), GET /graph (200, X-Graph-Cache: hit|miss, ADR-0014), POST /chat/stream (NDJSON 200, ADR-0019 §2.2), GET|POST /conversations, GET /conversations/{id}/messages, DELETE /conversations/{id}, POST /ingest/upload (202 — Feature U ADR-0020 §2), GET/PUT /import-schedule (Feature S ADR-0020 §4.6), POST /import-schedule/run-now (202 ADR-0020 §4.6). Auto OpenAPI → D4.")
        Component(watcher, "Watcher", "watchdog", "raw/sources/ events; mtime-then-hash gate (I1). Calls the seam only.")
        Component(orch, "IngestOrchestrator", "ingest/orchestrator.py", "Resolves provider from provider_config; reads capabilities(); ROUTES on supports_agentic_loop (I6 — never isinstance/class). Runs the orchestrated loop (analyze→generate→validate→retry, max_iter+token_budget, I7) OR delegates to CLI. Owns the Usage accumulator + cost-anomaly check. Sets status/pages_created/error_message on ingest_runs rows (migration 0006).")
        Component(resolver, "ConfigResolver", "provider_config_service.py", "operation+vault > vault > global precedence over provider_config.")
        Component(validator, "WikiPage validator", "in orchestrator", "type∈enum, title, non-empty sources[], lang, content (ADR-0007 §5).")
        Component(k5, "Wikilink parser", "wiki/links.py", "K5: [[Target|alias]] → links rows; dangling=True warn-not-error.")
        Component(k3, "Index/Overview writer", "wiki/index.py", "K3 index.md + F3 overview.md, per-write (I1).")
        Component(chatmod, "chat/ service module", "chat/context.py + chat/think.py + chat/stream.py", "context.py: builds light system context (purpose.md + overview.md, budget-capped, ADR-0019 §2.3). think.py: 2-state streaming scanner (OUTSIDE/INSIDE_THINK, 7-char partial-tag buffer, ADR-0019 §2.4). stream.py: bounded StreamingResponse generator (token_budget + 60s timeout, cost per-turn I7); writes conversations+messages rows (Alembic 0007); regenerate=delete-last-assistant + re-stream (AC-F6-4). Provider resolved via resolve_provider_config('chat') — never hardcoded (I6).")
        Component(prov, "InferenceProvider (ABC)", "ingest/provider/base.py", "analyze/generate/chat()/capabilities. The ONLY inference surface (I6). chat() stubbed in v0.2; bodies filled in v0.4 Phase 3 (ADR-0019 §5).")
        Component(ollama, "OllamaProvider", "provider/ollama.py", "Local. supports_agentic_loop=False. cost=$0.00. (I9 reuses running Ollama.) chat(): streams /api/chat stream=true; dev default path (qwen2.5:3b).")
        Component(apip, "ApiProvider", "provider/api.py", "Anthropic / OpenAI-compatible (base_url). Key from env only (§12). supports_agentic_loop=False. chat(): Anthropic SSE or OpenAI-compat SSE; usage via _record_usage (ADR-0009).")
        Component(clip, "CliAgentProvider", "provider/cli.py", "claude-agent-sdk, acceptEdits. supports_agentic_loop=True → delegated ingest.")
        Component(mcp, "MCP server (FastMCP)", "mcp/server.py", "stdio. Tools: search_wiki, write_page, get_page, list_pages. write_page reuses persist/embed/index primitives (I1,I5).")
        Component(uploadsanitizer, "Upload sanitizer", "upload.py", "Feature U (ADR-0020 §2.2). Pure functions: safe_source_name() — basename-only, no '..' or absolute, NUL/control strip, extension allow-list (.md/.txt/.markdown → else 415), ≤200-char clamp; resolve_under_sources() — containment-check (422 on escape). Unit-testable in isolation; no I/O. Called by POST /ingest/upload.")
        Component(importscheduler, "ImportScheduler", "import_scheduler.py", "Feature S (ADR-0020 §4.5). Single asyncio lifespan background task (NOT APScheduler — I9). Re-reads import_schedules on each tick; copy-then-watcher path (never calls ingest_file directly — I9/ADR-0003). Double-bounded: MAX_FILES + MAX_SECONDS per scan (I7). Single in-flight guard (no overlapping scans — I7). Non-recursive os.scandir. Hash-compare before copy (I1). Writes last_run_at/last_status/last_imported_count to import_schedules. run_now() method used by POST /import-schedule/run-now. Started in lifespan AFTER watcher; stopped on shutdown.")
        Component(gengine, "GraphEngine", "graph/engine.py", "F4. Reads pages+links from Postgres (never walks vault, I1). Builds 4-signal weighted edge list (direct x3, source-overlap x4, Adamic-Adar x1.5, type-affinity x1; ADR-0012). Runs SEEDED FA2 via python-igraph OFFLINE (seed=42, ADR-0013, I9). Single bounded pass (I7); logs node/edge count + duration.")
        Component(gcache, "GraphCache", "graph/cache.py", "I2. Debounces recompute on vault_state.data_version bump (default 5s, injectable clock; ADR-0014). Max one in-flight + one pending (I7). Tracks marker data_version → cache hit/miss. NEVER recomputes on a plain GET hit.")
        Component(gpersist, "Coord/edge persistence", "in engine.py", "One txn: UPDATE pages.x/y per node (column upsert, I1) + replace edges rows with weights. No vault/.md writes (I5).")
        ComponentDb(pg, "Postgres 16", "SQLAlchemy 2 + Alembic", "pages (+x,y v0.3), vault_state (data_version → graph trigger), provider_config, ingest_runs (+status/pages_created/error_message migration 0006, I7), links (K5), edges (v0.3: weighted graph, ADR-0012), conversations (v0.4 Phase 3, migration 0007, soft-delete, ADR-0019 §2.5), messages (v0.4 Phase 3, migration 0007, input_tokens/output_tokens/total_cost_usd I7, ADR-0019), import_schedules (M4-EXT Feature S, migration 0008: enabled/source_dir/frequency enum/last_run_at/last_status/last_imported_count/last_error — ADR-0020 §4.1, I7). D2 source of truth.")
