# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/

# Secrets — NEVER commit (AC-DC-5)
.env
*.env.local
*.env.*.local

# Vault content — gitignored; only .gitkeep files tracked
vault/raw/sources/*
vault/raw/assets/*
vault/wiki/**/*.md
vault/wiki/entities/
vault/wiki/concepts/
vault/wiki/sources/
vault/wiki/queries/
vault/wiki/synthesis/
vault/wiki/comparisons/
vault/wiki/.obsidian/
!vault/raw/sources/.gitkeep
!vault/raw/assets/.gitkeep

# Generated docs artefacts — D2 (ER) and D4 (OpenAPI) ARE committed so they are
# reviewable in-repo and the CI drift check (`make er`/`make openapi` + git diff) is meaningful (I8).
# D5 (v0.4): committed Playwright PNG screenshots ARE tracked; transient capture junk is not.
docs/screens/*
!docs/screens/*.png

# Playwright test output (transient — never committed)
/frontend/playwright-report/
/frontend/test-results/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Node (frontend)
node_modules/
.pnpm-store/
frontend/dist/
frontend/.vite/

# Tauri (Rust)
src-tauri/target/

# macOS
.DS_Store

# Tauri generated schemas (build-time)
src-tauri/gen/schemas/
* 2
