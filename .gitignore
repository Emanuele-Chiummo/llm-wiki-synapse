# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/

# Secrets — NEVER commit (AC-DC-5)
.env
*.env.local
*.env.*.local

# Vault content — gitignored; only .gitkeep files tracked
# The ENTIRE runtime vault is user data and must NEVER reach GitHub (owner mandate
# 2026-07-03). The backend recreates the folder structure on demand (vault.py,
# watcher.py — mkdir parents=True at every entry point), so no placeholder is needed.
vault/

# Generated docs artefacts — D2 (ER) and D4 (OpenAPI) ARE committed so they are
# reviewable in-repo and the CI drift check (`make er`/`make openapi` + git diff) is meaningful (I8).
# D5 (v0.4): committed Playwright PNG screenshots ARE tracked; transient capture junk is not.
docs/screens/*
!docs/screens/*.png
!docs/screens/v1.6.0/
!docs/screens/v1.6.0/*.png

# Playwright test output (transient — never committed)
/frontend/playwright-report/
/frontend/test-results/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Node (frontend)
node_modules/
.pnpm-store/
frontend/dist/
frontend/.vite/

# Tauri (Rust)
src-tauri/target/

# macOS
.DS_Store

# Tauri generated schemas (build-time)
src-tauri/gen/schemas/

# iOS Tauri target — parked on branch feature/ios-target for v2.0; keep it off
# sprint branches so `git add -A` can't reintroduce it. (No effect on files already
# tracked by feature/ios-target — git ignores this rule for tracked paths.)
src-tauri/gen/apple/

# iCloud sync duplicates ("name 2.ext") — the repo lives in an iCloud-synced folder
* 2
* 2.*
* 3
* 3.*

# MkDocs build output (generated by make docs-build / CI)
site/

# Agent-skills pack (addyosmani/agent-skills) — installed locally via `npx skills add`.
# Build-time assist only; not part of the Synapse runtime. Kept out of the repo.
.agents/
.claude/skills/
skills-lock.json
backups/
