    Rel(pipeline, provider, "complete() / chat() / capabilities() via ABC (I6)", "in-process")
    Rel(blockloop, orch, "persist_metadata / upsert_vector / bump_version (primitives via orch.*)", "in-process")
    Rel(blockloop, provider, "complete(analysis_prompt) + complete(generation_prompt)", "in-process")
    Rel(provider, ollamasvc, "Local analyze/generate/complete", "HTTP /api/chat")
    Rel(provider, anthropic, "API analyze/generate; CLI delegated agent loop", "HTTPS")
    Rel(provider, mcp, "CliAgentProvider: in-process MCP SDK server (write_page/search_wiki)", "MCP in-process")
    Rel(mcp, pg, "write_page via shared persist primitives", "SQLAlchemy")
    Rel(mcp, qdrant, "search_wiki embed+query (I9)", "HTTP / gRPC")
    Rel(mcp, vaultfs, "write_page writes wiki/ pages", "file I/O")
    Rel(orch, pg, "Upserts pages/links; writes ingest_runs; bumps data_version", "SQLAlchemy")
    Rel(orch, bgem3, "Embeds each generated page (via EmbeddingClient)", "HTTP / JSON")
    Rel(orch, qdrant, "Upserts / deletes page vectors", "HTTP / gRPC")
    Rel(orch, vaultfs, "Writes wiki/ pages, index.md, log.md", "file I/O")
