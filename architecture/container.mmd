    title Container Diagram — Synapse 2.0.0

    Person(emanuele, "Emanuele", "Vault owner / operator")

    System_Boundary(synapse, "Synapse (docker compose)") {
        Container(api, "FastAPI service", "Python 3.11 / FastAPI", "REST + MCP endpoints. All HTTP errors use the stable {error: {code, message, status, details}} envelope (ADR-0086, 2.0.0 breaking change). Routes: /pages, /graph, /ingest/*, /chat/*, /search, /review/*, /research/*, /ops/*, /config/*, /clip, /status, /health, /projects, /vault/*. Auto OpenAPI → D4.")
        Container(watcher, "Watcher", "watchdog (same process)", "raw/sources/ CREATE/MODIFY/DELETE events. mtime-then-hash gate (I1, no rescan). Calls app.ingest.pipeline.ingest_file() — the public entry point (2.0.0: direct import, no orchestrator facade).")
        Container(pipeline, "Ingest Pipeline", "app/ingest/pipeline.py", "Public entry points ingest_file / delete_file / run_ingest_pipeline. Change gate (mtime-then-hash, I1). Capability-aware routing on supports_agentic_loop (I6): ORCHESTRATED (block-based loop, no JSON path in 2.0.0) or DELEGATED (CLI). Owns ingest_runs lifecycle + cost accounting (I7). Coordinates pipeline.py → block_loop.py → block_writer.py → writer.py.")
        Container(blockloop, "Block-based ingest engine", "app/ingest/block_loop.py + blocks.py + block_writer.py", "The ONLY generation engine (2.0.0: JSON loop removed). Bounded analysis + block-generation loop (max_iter + token_budget, I7). Parses FILE/REVIEW blocks. Writes pages via block_writer.py. REVIEW blocks enqueued (F9). Source chunking for long documents (long_source.py). Provider-agnostic (I6).")
        Container(orch, "Persistence primitives", "app/ingest/orchestrator.py", "Low-level write primitives ONLY: persist_metadata, upsert_vector, append_log, bump_version, reindex_wiki_page_body, apply_domain_tags, apply_page_type, _update_overview. 2.0.0: all compatibility re-exports (IngestError, IngestResult, run_ingest_pipeline, write_wiki_page) removed. Importers pull from pipeline.py / writer.py / context.py directly.")
        Container(writer, "Wiki page writer", "app/ingest/writer.py + context.py", "write_wiki_page: canonical wiki-page write seam (upsert by vault_id+file_path, hash over full file bytes, I1/I5). context.py: ingest context assembly (purpose.md, schema.md, existing-page catalogue). Both are first-class importable modules — NOT re-exported through orchestrator.py (2.0.0).")
        Container(provider, "InferenceProvider layer", "app/ingest/provider/ (base/ollama/api/cli)", "The ONLY inference surface (I6). 3 backends: OllamaProvider / ApiProvider (Anthropic + OpenAI-compat) / CliAgentProvider (claude-agent-sdk). complete() for single-turn seams; chat() for streaming; delegate_ingest() for CLI agentic loop. No model id / key / endpoint leaks outside this package.")
        Container(mcp, "MCP server", "app/mcp/server.py (FastMCP, stdio + HTTP)", "Tools: search_wiki, write_page, get_page, list_pages, graph_neighborhood, list_reviews, read_source, resolve_review, trigger_rescan. write_page reuses persist/embed/index primitives (I1, I5). Multi-vault: optional vault param on every tool. write_page / resolve_review / trigger_rescan gated by remote MCP write toggle (ADR-0072). CliAgentProvider uses in-process MCP SDK server (separate from the HTTP/stdio public server).")
        ContainerDb(pg, "Postgres 16", "PostgreSQL / SQLAlchemy 2 + Alembic", "Tables: pages (+x/y/summary), vault_state (data_version), provider_config, ingest_runs (+diagnostics), links, edges, conversations, messages, import_schedules, lint_findings, review_items, api_tokens (scoped/revocable, ADR-PF-AUTH-1). Source of truth for ER diagram (I8, D2).")
    }

    System_Ext(ollamasvc, "Ollama", "Local LLM (RTX 3060, running, I9)", "Local provider backend.")
    System_Ext(anthropic, "Anthropic API / OpenAI-compat", "External; key via env or encrypted DB (ADR-0071)", "API + CLI provider backends.")
    System_Ext(qdrant, "Qdrant", "Vector DB (external, TrueNAS)", "synapse_pages. search_wiki + page vectors.")
    System_Ext(bgem3, "bge-m3 embedding service", "External (TrueNAS), via EMBEDDING_URL", "No local model (I9).")
    System_Ext(vaultfs, "Vault filesystem (multi-vault)", "raw/ ro · wiki/ rw — per project dir", "Valid Obsidian vaults (I5). Multi-vault: project registry maps vault_id → root path.")
    System_Ext(searxng, "SearXNG (+ opt-in providers)", "Default web-search backend (I9, ADR-0066)", "Deep Research F10 + web-search toggle in chat (B2).")

    Rel(emanuele, api, "REST/MCP; provider config; triggers ingest; reads pages; chats", "HTTP / JSON — stable error envelope (ADR-0086)")
    Rel(emanuele, vaultfs, "Drops sources; opens wiki/ in Obsidian", "filesystem")

    Rel(watcher, pipeline, "ingest_file(path)", "in-process (direct import, 2.0.0)")
