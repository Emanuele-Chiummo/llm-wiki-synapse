# Synapse backend environment variables
# Copy to .env and fill in values. NEVER commit .env (AC-DC-5).
#
# All config is read from these variables — no secrets in code (CLAUDE.md §12, I9).

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://synapse:synapse@localhost:5432/synapse

# ── Qdrant (already running on TrueNAS — I9) ──────────────────────────────────
QDRANT_URL=http://truenas:6333
QDRANT_COLLECTION=synapse_pages

# ── Embedding: bge-m3 via Ollama on TrueNAS (I9 — reuse existing service) ─────
# POST body: {"model": "<EMBEDDING_MODEL>", "prompt": "<text>"}
# Response:  {"embedding": [<floats>]}
EMBEDDING_URL=http://truenas:11434/api/embeddings
EMBEDDING_MODEL=bge-m3
# REQUIRED — no silent default. Run bge-m3 and check its output length.
# bge-m3 standard variant: 1024. Verify against your running instance (ADR-0004).
EMBEDDING_DIM=1024

# ── Vault ─────────────────────────────────────────────────────────────────────
VAULT_ID=default
VAULT_PATH=../vault
