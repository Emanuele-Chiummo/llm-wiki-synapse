# Synapse backend environment variables
# Copy to .env and fill in values. NEVER commit .env (AC-DC-5).
#
# All config is read from these variables — no secrets in code (CLAUDE.md §12, I9).

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://synapse:synapse@localhost:5432/synapse

# ── Qdrant (already running on TrueNAS — I9) ──────────────────────────────────
QDRANT_URL=http://truenas:6333
QDRANT_COLLECTION=synapse_pages

# ── Embedding: bge-m3 via Ollama on TrueNAS (I9 — reuse existing service) ─────
# POST body: {"model": "<EMBEDDING_MODEL>", "prompt": "<text>"}
# Response:  {"embedding": [<floats>]}
EMBEDDING_URL=http://truenas:11434/api/embeddings
EMBEDDING_MODEL=bge-m3
# REQUIRED — no silent default. Run bge-m3 and check its output length.
# bge-m3 standard variant: 1024. Verify against your running instance (ADR-0004).
EMBEDDING_DIM=1024
# Request/response adapter (ADR-0031, Feature C) — explicit, not auto-detected.
#   ollama (default): POST {"model","prompt"} -> {"embedding":[...]}
#   openai          : POST {"model","input"}  -> {"data":[{"embedding":[...]}]}
EMBEDDING_FORMAT=ollama
# SECRET (optional). When set: Authorization: Bearer <key> on every request.
# Leave unset for local bge-m3. Never logged, never returned by GET /config/embedding.
# EMBEDDING_API_KEY=sk-...

# ── Vault ─────────────────────────────────────────────────────────────────────
VAULT_ID=default
VAULT_PATH=../vault

# ── Remote MCP over HTTP (Feature A, ADR-0029) ──────────────────────────────────
# Bearer token secret for MCP /mcp/server. When unset, HTTP MCP NOT mounted (fail-closed).
# Generate with: openssl rand -base64 32
# Do NOT commit a real value — set at deploy time only.
# MCP_AUTH_TOKEN=

# Allow write_page on the remote MCP HTTP surface. Default false (read-only).
# Set true ONLY if you want remote clients (claude.ai) to mutate the vault.
MCP_REMOTE_WRITE_ENABLED=false
