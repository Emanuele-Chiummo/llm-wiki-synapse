{
  "name": "synapse-frontend",
  "version": "1.5.1",
  "private": true,
  "description": "Synapse — self-hosted LLM wiki workspace with knowledge graph and provider-selectable AI",
  "type": "module",
  "scripts": {
    "predev": "node scripts/copy-changelog.mjs",
    "dev": "vite",
    "prebuild": "node scripts/copy-changelog.mjs",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "cd .. && node frontend/node_modules/@tauri-apps/cli/tauri.js",
    "tauri:dev": "cd .. && node frontend/node_modules/@tauri-apps/cli/tauri.js dev",
    "tauri:build": "cd .. && node frontend/node_modules/@tauri-apps/cli/tauri.js build",
    "lint": "eslint src --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e:v09": "playwright test e2e/v09-happy-paths.spec.ts"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.4",
    "@tanstack/react-virtual": "^3.14.4",
    "@tauri-apps/plugin-http": "^2",
    "@tauri-apps/plugin-notification": "^2.0.0",
    "@tauri-apps/plugin-process": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.0.0",
    "@types/dompurify": "^3.0.5",
    "dompurify": "^3.4.11",
    "graphology": "^0.25.4",
    "i18next": "^26.3.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "katex": "^0.16.47",
    "lucide-react": "^1.22.0",
    "marked": "^18.0.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.8",
    "react-resizable-panels": "^4.12.0",
    "sigma": "^3.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tanstack/virtual-core": "^3.13.0",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/katex": "^0.16.8",
    "@types/node": "^26.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^17.7.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^2.1.0"
  },
  "allowScripts": {
    "esbuild@0.21.5": true
  }
}
