# Synapse frontend environment — copy to .env.local and fill in
# No secrets belong here — API keys live in the backend only.

# Browser API base (inlined into the bundle at build time by Vite).
# Leave EMPTY (default) for same-origin relative paths — correct for localhost, Tailscale, Cloudflare Tunnel.
# Set to an absolute URL ONLY for split-origin deployments (static bundle and API on different hosts).
# NEVER set this to a Docker-internal hostname like synapse-backend — the browser cannot resolve it.
VITE_API_BASE=

# Dev-only: Vite dev proxy target (server-side, NOT exposed to the browser).
# In docker-compose.dev.yml this is set to http://synapse-backend:8000 (Docker network).
# For bare-metal `npm run dev`, set to http://localhost:8000 or your backend URL.
BACKEND_PROXY_TARGET=http://localhost:8000

# Vault ID to load on startup (optional; can also be set via UI in v0.4)
# VITE_DEFAULT_VAULT_ID=default
