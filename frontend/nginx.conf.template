# Synapse frontend nginx config (template).
# Rendered at container start by the nginx image entrypoint: envsubst expands
# ${BACKEND_PROXY_TARGET} and writes this to /etc/nginx/conf.d/default.conf.
# Only real env vars are substituted; nginx runtime vars ($uri, $host, …) survive.

# Streaming/websocket upgrade helper (used by the API proxy below).
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    listen 80;
    server_name _;

    root /usr/share/nginx/html;
    index index.html;

    # ── Security response headers (audit finding C3) ─────────────────────────
    # Note: "Always Use HTTPS" and HSTS preload are enforced at the Cloudflare
    # edge (dashboard → SSL/TLS → Edge Certificates → HSTS toggle). The HSTS
    # header below is the origin-level complement for non-CF connections.
    #
    # Nginx add_header inheritance: a location block only inherits add_header
    # directives from the parent server block when the location itself defines
    # NONE of its own. Neither location block below currently defines any
    # add_header, so these server-level directives are inherited by both the
    # SPA (location /) and the API proxy. If any location ever gains its own
    # add_header, the full security set MUST be repeated there as well.
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options    "nosniff"                              always;
    add_header X-Frame-Options           "DENY"                                 always;
    # frame-ancestors only — a full default-src/script-src CSP would break
    # the SPA's inline styles and is out of scope for this change.
    add_header Content-Security-Policy   "frame-ancestors 'none'"               always;
    add_header Referrer-Policy           "no-referrer"                          always;
    add_header Permissions-Policy        "geolocation=(), microphone=(), camera=(), interest-cohort=()" always;

    # Docker embedded DNS: resolve the backend service name at request time, so a
    # backend container restart (new IP) is picked up without an nginx reload.
    resolver 127.0.0.11 ipv6=off valid=30s;

    # Generous body cap; the backend enforces its own MAX_UPLOAD_BYTES.
    client_max_body_size 64m;

    # ── API reverse-proxy ─────────────────────────────────────────────────────
    # Forward the API path prefixes to the backend so the browser keeps its
    # relative base. Keep this list in sync with API_PREFIXES in vite.config.ts.
    location ~ ^/(graph|pages|status|ingest|provider|conversations|chat|import-schedule|config|mcp|research|review|search|clip|web-search|lint|sources|overview|links|scenarios|costs|stats|ops|vault|health|export|api)(/|$) {
        set $upstream ${BACKEND_PROXY_TARGET};
        proxy_pass $upstream$request_uri;

        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Streaming responses (chat tokens, deep-research / ingest progress via SSE).
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_buffering  off;
        proxy_cache      off;
        proxy_read_timeout  3600s;
        proxy_send_timeout  3600s;
    }

    # ── SPA shell ─────────────────────────────────────────────────────────────
    # Static assets, then client-side routing fallback. API paths never reach here.
    location / {
        try_files $uri $uri/ /index.html;
    }
}
