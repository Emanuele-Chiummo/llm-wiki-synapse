# Synapse environment variables — copy to .env and customize
# NEVER commit .env — all secrets stay local (AC-DC-5, CLAUDE.md §12)
#
# This is the canonical file for all environment variables used by the stack.
# Keep the backend/.env.example in sync for local development.

# ──────────────────────────────────────────────────────────────────────────
# PostgreSQL (docker-compose: postgres service)
# ──────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://synapse:synapse@postgres:5432/synapse
# Local dev (without docker):
# DATABASE_URL=postgresql+asyncpg://synapse:synapse@localhost:5432/synapse

# ──────────────────────────────────────────────────────────────────────────
# Qdrant vector store (already running on TrueNAS — I9)
# ──────────────────────────────────────────────────────────────────────────
# TrueNAS (Docker): use host.docker.internal to reach the host
QDRANT_URL=http://host.docker.internal:6333
# TrueNAS (local dev or Tailscale): replace with actual IP or hostname
# QDRANT_URL=http://truenas.local:6333
# QDRANT_URL=http://100.x.x.x:6333  (Tailscale IP)
QDRANT_COLLECTION=synapse_pages

# ──────────────────────────────────────────────────────────────────────────
# Embeddings: bge-m3 via Ollama on TrueNAS (I9 — reuse existing GPU service)
# ──────────────────────────────────────────────────────────────────────────
# Ollama endpoint for embeddings (runs on RTX 3060, 12 GB VRAM)
# POST /api/embeddings with {"model": "bge-m3", "prompt": "<text>"}
EMBEDDING_URL=http://host.docker.internal:11434/api/embeddings
# Local dev:
# EMBEDDING_URL=http://localhost:11434/api/embeddings
# Tailscale:
# EMBEDDING_URL=http://100.x.x.x:11434/api/embeddings

# Model name and dimension (ADR-0004)
EMBEDDING_MODEL=bge-m3
# REQUIRED env var — no silent default
# bge-m3 standard: 1024 (verify against your running Ollama instance)
EMBEDDING_DIM=1024

# ──────────────────────────────────────────────────────────────────────────
# Generative Ollama for the Local InferenceProvider (F17 — NB-5)
# ──────────────────────────────────────────────────────────────────────────
# Base URL of the Ollama instance used for analyze/generate (e.g. qwen2.5:3b).
# Same Ollama as embeddings; the model id itself comes from a provider_config row (I6).
OLLAMA_URL=http://host.docker.internal:11434
# Local dev:  OLLAMA_URL=http://localhost:11434
# Tailscale:  OLLAMA_URL=http://100.x.x.x:11434

# ──────────────────────────────────────────────────────────────────────────
# Vault configuration
# ──────────────────────────────────────────────────────────────────────────
# Logical vault identifier (supports multi-vault in future)
VAULT_ID=default
# Absolute or relative path to vault root (contains raw/, wiki/, schema.md)
# Docker: /vault (bind-mounted in compose)
# Local: ../vault or /absolute/path
VAULT_PATH=/vault

# ──────────────────────────────────────────────────────────────────────────
# Optional: External services (v0.2+, commented out for v0.1)
# ──────────────────────────────────────────────────────────────────────────
# SearXNG (web search backend, reuse existing TrueNAS service — I9)
# SEARXNG_URL=http://host.docker.internal:8888
# SearXNG_URL=http://100.x.x.x:8888 (Tailscale)

# ──────────────────────────────────────────────────────────────────────────
# Optional: Inference provider (v0.2+, defaults to orchestrated loop)
# ──────────────────────────────────────────────────────────────────────────
# PROVIDER_TYPE=local  # or api, cli
# PROVIDER_MODEL=llama2  # for local (Ollama)
# ANTHROPIC_API_KEY=...  # for api provider
