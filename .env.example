# Synapse environment variables — copy to .env and customize
# NEVER commit .env — all secrets stay local (AC-DC-5, CLAUDE.md §12)
#
# This is the canonical file for all environment variables used by the stack.
# Keep the backend/.env.example in sync for local development.

# ──────────────────────────────────────────────────────────────────────────
# PostgreSQL (docker-compose: postgres service)
# ──────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://synapse:synapse@postgres:5432/synapse
# Local dev (without docker):
# DATABASE_URL=postgresql+asyncpg://synapse:synapse@localhost:5432/synapse

# ──────────────────────────────────────────────────────────────────────────
# Qdrant vector store (already running on TrueNAS — I9)
# ──────────────────────────────────────────────────────────────────────────
# TrueNAS (Docker): use host.docker.internal to reach the host
QDRANT_URL=http://host.docker.internal:6333
# TrueNAS (local dev or Tailscale): replace with actual IP or hostname
# QDRANT_URL=http://truenas.local:6333
# QDRANT_URL=http://100.x.x.x:6333  (Tailscale IP)
QDRANT_COLLECTION=synapse_pages

# ──────────────────────────────────────────────────────────────────────────
# Embeddings: bge-m3 via Ollama on TrueNAS (I9 — reuse existing GPU service)
# ──────────────────────────────────────────────────────────────────────────
# Ollama endpoint for embeddings (runs on RTX 3060, 12 GB VRAM)
# POST /api/embeddings with {"model": "bge-m3", "prompt": "<text>"}
EMBEDDING_URL=http://host.docker.internal:11434/api/embeddings
# Local dev:
# EMBEDDING_URL=http://localhost:11434/api/embeddings
# Tailscale:
# EMBEDDING_URL=http://100.x.x.x:11434/api/embeddings

# Model name and dimension (ADR-0004)
EMBEDDING_MODEL=bge-m3
# REQUIRED env var — no silent default
# bge-m3 standard: 1024 (verify against your running Ollama instance)
EMBEDDING_DIM=1024

# Embedding request/response adapter (ADR-0031, Feature C) — explicit, not auto-detected.
#   ollama (default): POST {"model","prompt"} -> {"embedding":[...]}  (bge-m3 above)
#   openai          : POST {"model","input"}  -> {"data":[{"embedding":[...]}]}
#                     (point EMBEDDING_URL at an OpenAI-style /v1/embeddings endpoint)
EMBEDDING_FORMAT=ollama
# SECRET (optional). When set, every embedding request sends Authorization: Bearer <key>.
# Leave unset for local bge-m3 (no auth). Never logged, never returned by any endpoint.
# EMBEDDING_API_KEY=sk-...

# ──────────────────────────────────────────────────────────────────────────
# Generative Ollama for the Local InferenceProvider (F17 — NB-5)
# ──────────────────────────────────────────────────────────────────────────
# Base URL of the Ollama instance used for analyze/generate (e.g. qwen2.5:3b).
# Same Ollama as embeddings; the model id itself comes from a provider_config row (I6).
OLLAMA_URL=http://host.docker.internal:11434
# Local dev:  OLLAMA_URL=http://localhost:11434
# Tailscale:  OLLAMA_URL=http://100.x.x.x:11434

# ──────────────────────────────────────────────────────────────────────────
# Vault configuration
# ──────────────────────────────────────────────────────────────────────────
# Logical vault identifier (supports multi-vault in future)
VAULT_ID=default

# ──────────────────────────────────────────────────────────────────────────
# CORS — browser origins allowed to call the API (frontend viewer / PWA)
# ──────────────────────────────────────────────────────────────────────────
# Comma-separated. Default covers the Vite dev server. Set to your PWA/Tauri origin in prod.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Absolute or relative path to vault root (contains raw/, wiki/, schema.md)
# Docker: /vault (bind-mounted in compose)
# Local: ../vault or /absolute/path
VAULT_PATH=/vault

# ──────────────────────────────────────────────────────────────────────────
# Deployment trust boundary and REST API authentication (ADR-0052 / ADR-0075)
# ──────────────────────────────────────────────────────────────────────────
# local  = backward-compatible loopback/trusted-machine mode; auth token optional.
# server = network-reachable mode; startup FAILS unless a strong token is configured.
SYNAPSE_DEPLOYMENT_MODE=local
# Host address for Docker's published API port. Keep loopback for local use.
# Set 0.0.0.0 only with deployment mode `server` and a strong token.
SYNAPSE_BIND_HOST=127.0.0.1

# Required when SYNAPSE_DEPLOYMENT_MODE=server. Env-only secret; never commit a real value.
# Generate one with: openssl rand -hex 32
# Server validation requires >=32 characters, no whitespace and >=8 distinct characters.
# SYNAPSE_AUTH_TOKEN=

# ──────────────────────────────────────────────────────────────────────────
# Optional: External services (v0.2+, commented out for v0.1)
# ──────────────────────────────────────────────────────────────────────────
# SearXNG (web search backend, reuse existing TrueNAS service — I9)
# SEARXNG_URL=http://host.docker.internal:8888
# SearXNG_URL=http://100.x.x.x:8888 (Tailscale)

# ──────────────────────────────────────────────────────────────────────────
# Inference provider authentication — choose ONE method (F17, ADR-0042)
# ──────────────────────────────────────────────────────────────────────────
#
# Three mutually exclusive authentication paths for the AI provider:
#
# METHOD 1: ANTHROPIC_API_KEY (per-token billing, default if set)
# ─────────────────────────────────────────────────────────────────
# Use for API provider (Anthropic Messages API) or CLI provider with pay-as-you-go billing.
# Format: sk-ant-... (API key from console.anthropic.com)
# Cost: Billed per token used.
# WARNING: If ANTHROPIC_API_KEY is set (even to an empty string, e.g., `export
# ANTHROPIC_API_KEY=""`), it takes precedence and FORCES per-token billing.
# Subscription auth will NOT work if this is set. Must be completely UNSET.
#   ANTHROPIC_API_KEY=sk-ant-your-api-key-here
#
# METHOD 2: CLAUDE_CODE_OAUTH_TOKEN (Pro/Max subscription, $0 cost)
# ─────────────────────────────────────────────────────────────────
# Use for CLI provider with Claude Pro or Claude Max subscription.
# How to get the token:
#   1. On your host (not in container), run: claude setup-token
#   2. Copy the printed OAuth token (sk-ant-oat01-...)
#   3. Set it here: CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...
# IMPORTANT: Only works if ANTHROPIC_API_KEY is UNSET (completely absent from env).
# Cost: $0 marginal cost; uses your existing subscription.
#   CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-your-oauth-token-here
#
# METHOD 3: CLAUDE_CODE_USE_SUBSCRIPTION (ambient subscription auth)
# ──────────────────────────────────────────────────────────────────
# Use this flag to tell the CLI provider to read subscription auth from the host's
# ~/.claude/ directory (if mounted into the container).
# IMPORTANT: Only works if ANTHROPIC_API_KEY is UNSET.
#   CLAUDE_CODE_USE_SUBSCRIPTION=true
#
# SUMMARY TABLE:
# ┌─────────────────────────┬──────────────────────┬──────────────┐
# │ Method                  │ Provider Type        │ Cost         │
# ├─────────────────────────┼──────────────────────┼──────────────┤
# │ ANTHROPIC_API_KEY       │ api, cli             │ per-token    │
# │ CLAUDE_CODE_OAUTH_TOKEN │ cli                  │ subscription │
# │ CLAUDE_CODE_USE_SUBSCRIPTION │ cli           │ subscription │
# └─────────────────────────┴──────────────────────┴──────────────┘
#
# Example: Use Pro subscription for CLI provider (no cost)
#   Unset: ANTHROPIC_API_KEY=
#   Set:   CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...
#
# Example: Use API provider with paid key
#   Set: ANTHROPIC_API_KEY=sk-ant-...
#   Unset: CLAUDE_CODE_OAUTH_TOKEN=
#
# NOTE: which provider (local/api/cli) and which model is used is NOT set here —
# it is chosen at runtime in the UI (Settings → LLM Models), backed by the
# provider_config table (I6). These env vars only supply the CREDENTIALS above.

# ──────────────────────────────────────────────────────────────────────────
# Remote MCP over HTTP (Feature A, ADR-0029) — optional
# ──────────────────────────────────────────────────────────────────────────
# Enable the remote MCP HTTP surface at /mcp/server (mounted on FastAPI).
# When unset, the HTTP MCP surface is NOT mounted (fail-closed).
# Must be a strong secret; never commit a real value. Generate with:
#   openssl rand -base64 32
# Then set it as an environment variable before starting the stack.
# MCP_AUTH_TOKEN=

# Allow write_page over the remote MCP HTTP surface.
# Default false: only read tools (search_wiki, get_page, list_pages) are exposed.
# Set to true ONLY if you want claude.ai or another remote MCP client to mutate the vault.
# Even when true, the endpoint still requires a valid MCP_AUTH_TOKEN bearer token (§2.2).
MCP_REMOTE_WRITE_ENABLED=false
