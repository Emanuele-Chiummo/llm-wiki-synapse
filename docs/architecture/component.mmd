    title Component Diagram — Synapse v0.4 Phase 2 (M4 "Usable & fluid" — F1 shell + F17-UI + F14/F16)

    Container_Boundary(api, "FastAPI service") {
        Component(rest, "REST + provider + graph + ingest/runs endpoints", "FastAPI routers", "GET/POST /provider/config, POST /ingest/trigger (202), GET /ingest/runs (ADR-0018 §7), GET /graph (200, X-Graph-Cache: hit|miss, ADR-0014). Auto OpenAPI → D4.")
        Component(watcher, "Watcher", "watchdog", "raw/sources/ events; mtime-then-hash gate (I1). Calls the seam only.")
        Component(orch, "IngestOrchestrator", "ingest/orchestrator.py", "Resolves provider from provider_config; reads capabilities(); ROUTES on supports_agentic_loop (I6 — never isinstance/class). Runs the orchestrated loop (analyze→generate→validate→retry, max_iter+token_budget, I7) OR delegates to CLI. Owns the Usage accumulator + cost-anomaly check. Sets status/pages_created/error_message on ingest_runs rows (migration 0006).")
        Component(resolver, "ConfigResolver", "provider_config_service.py", "operation+vault > vault > global precedence over provider_config.")
        Component(validator, "WikiPage validator", "in orchestrator", "type∈enum, title, non-empty sources[], lang, content (ADR-0007 §5).")
        Component(k5, "Wikilink parser", "wiki/links.py", "K5: [[Target|alias]] → links rows; dangling=True warn-not-error.")
        Component(k3, "Index/Overview writer", "wiki/index.py", "K3 index.md + F3 overview.md, per-write (I1).")
        Component(prov, "InferenceProvider (ABC)", "ingest/provider/base.py", "analyze/generate/chat(stub)/capabilities. The ONLY inference surface (I6).")
        Component(ollama, "OllamaProvider", "provider/ollama.py", "Local. supports_agentic_loop=False. cost=$0.00. (I9 reuses running Ollama.)")
        Component(apip, "ApiProvider", "provider/api.py", "Anthropic / OpenAI-compatible (base_url). Key from env only (§12). supports_agentic_loop=False.")
        Component(clip, "CliAgentProvider", "provider/cli.py", "claude-agent-sdk, acceptEdits. supports_agentic_loop=True → delegated ingest.")
        Component(mcp, "MCP server (FastMCP)", "mcp/server.py", "stdio. Tools: search_wiki, write_page, get_page, list_pages. write_page reuses persist/embed/index primitives (I1,I5).")
        Component(gengine, "GraphEngine", "graph/engine.py", "F4. Reads pages+links from Postgres (never walks vault, I1). Builds 4-signal weighted edge list (direct x3, source-overlap x4, Adamic-Adar x1.5, type-affinity x1; ADR-0012). Runs SEEDED FA2 via python-igraph OFFLINE (seed=42, ADR-0013, I9). Single bounded pass (I7); logs node/edge count + duration.")
        Component(gcache, "GraphCache", "graph/cache.py", "I2. Debounces recompute on vault_state.data_version bump (default 5s, injectable clock; ADR-0014). Max one in-flight + one pending (I7). Tracks marker data_version → cache hit/miss. NEVER recomputes on a plain GET hit.")
        Component(gpersist, "Coord/edge persistence", "in engine.py", "One txn: UPDATE pages.x/y per node (column upsert, I1) + replace edges rows with weights. No vault/.md writes (I5).")
        ComponentDb(pg, "Postgres 16", "SQLAlchemy 2 + Alembic", "pages (+x,y v0.3), vault_state (data_version → graph trigger), provider_config, ingest_runs (+status/pages_created/error_message migration 0006, I7), links (K5), edges (v0.3: weighted graph, ADR-0012). D2 source of truth.")
    }

    Container_Boundary(fe, "Frontend — 3-panel shell + NavRail + Ingest + Provider + Settings (v0.4 Phase 2, ADR-0017/0018)") {
        Component(appshell, "AppShell", "AppShell.tsx", "Top-level layout (Phase 2 rewire): <Header> + row(<NavRail> + <SectionRouter>) + <ActivityBar> + <ToastHost>. No layout code, no force-graph import (I2).")
        Component(header, "Header", "Header.tsx", "Branding + <ProviderSelector/> wired in Phase 2 (F17). No hardcoded provider (I6).")
        Component(navrail, "NavRail", "nav/NavRail.tsx", "~48px persistent left icon rail (ADR-0018 §1). Sections: Pages/Graph/Ingest/Settings (active=soft tint); Chat disabled (Phase 3). Reads activeSection+setActiveSection from graphStore; badge reads useIngestRunningCount() from ingestStore. Keyboard arrow nav; role=navigation; i18n labels. Never imports layout code (I2/I3).")
        Component(sectionrouter, "SectionRouter", "SectionRouter.tsx", "Reads activeSection (scalar) from graphStore; keyed switch: pages→PanelGroup, graph→GraphPanel full-bleed, ingest→IngestView+IngestRunDetail, settings→SettingsPanel. I3: subscribes to activeSection only.")
        Component(panelgroup, "PanelGroup", "panels/PanelGroup.tsx", "Horizontal 3-panel group via react-resizable-panels. PanelResizeHandle: role=separator, aria-orientation=vertical, arrow-key resize. No rAF/JS layout loop (AC-F1-7). min sizes ~[15%,40%,20%]; onLayout hook for Phase-2 persistence. Rendered only when activeSection=pages.")
        Component(navtree, "NavTree", "nav/NavTree.tsx + nav/useNavTreeData.ts", "Left panel (role=navigation). Fetches GET /pages; groups by type (concept/entity/source/synthesis/comparison/other); flattens to TreeRow[]; virtualizes via useVirtualizer (TanStack Virtual, I4, AC-F1-2, ≤50 DOM rows). Row click → selectPage(id,'tree') on shared selectedNodeId. role=tree/treeitem/group.")
        Component(maintabs, "MainTabs", "center/MainTabs.tsx", "Center (role=main). Tab strip: [Graph] active, [Chat aria-disabled] Phase-3 stub hosting ScenarioTemplates. Reads/sets activeTab from graphStore UI slice. role=tablist/tab/tabpanel; roving tabindex.")
        Component(graphpanel, "GraphPanel", "center/GraphPanel.tsx", "Thin wrapper: mounts the EXISTING <GraphViewer/> unchanged (height:100%; min-height:0 for sigma ResizeObserver). No layout code added. T-NCL-001..022 intact. Also used as full-bleed view when activeSection=graph.")
        Component(viewer, "GraphViewer", "React 19 + Vite + sigma.js", "I2/I4. UNCHANGED from v0.3. Renders precomputed coords in ONE WebGL canvas. NEVER imports/runs forceatlas2/d3-force/any client layout (ADR-0015, P0 block). Node click → setSelectedNodeId (shared key). No T-NCL assertions changed.")
        Component(previewpanel, "PreviewPanel", "preview/PreviewPanel.tsx", "Right panel (role=complementary). Subscribes to selectedNodeId via selectSelectedNodeId. Phase 1: read-only metadata+relationship inspector (title/type/sources/neighbors/degree) from GET /pages/{id} + in-memory nodes/edges. 'No document body — demo node' empty state. NOT an editor (I4, AC-F1-3). GET /pages/{id}/content reserved for Phase 3.")
        Component(activitybar, "ActivityBar", "activity/ActivityBar.tsx", "Bottom bar (role=status). vault name, active provider (reads selectActiveProvider from providerStore — Phase 2 filled), last-ingest timestamp, data_version from GET /status + graph store. AC-F1-5.")
        Component(scenariotemplates, "ScenarioTemplates", "common/ScenarioTemplates.tsx", "≥2 scenario template buttons (AC-F1-6). Phase 1: rendered in the Chat-stub tab region; pre-fill a disabled chat-input placeholder. Wired to chat store in Phase 3.")
        Component(toast, "Toast + ToastHost", "common/Toast.tsx", "Singleton toast system (ADR-0018 §3). showToast(msg, severity) called from IngestView + ProviderSelector. ToastHost mounts once in AppShell outside all panels. severity: success|error|info.")
        Component(ingestview, "IngestView", "ingest/IngestView.tsx", "Center pane of Ingest section (ADR-0018 §3). Header with title+badge+Run-Ingest button; inline form (file_path → POST /ingest/trigger); polling starts on mount, stops when no running runs; delegates list to IngestRunList. Reads ingestStore via typed selectors (I3).")
        Component(ingestrunlist, "IngestRunList", "ingest/IngestRunList.tsx", "TanStack-Virtual list of run cards (I4, ≤40 DOM rows). Per card: StatusBadge, provider_type, pages_created, cost at 4dp (I7), relative time, truncated error. Click → setSelectedRunId. Load-more paging (fetchMore offset). Reads ingestStore.")
        Component(ingestrundetail, "IngestRunDetail", "ingest/IngestRunDetail.tsx", "Right pane of Ingest section. Selected run manifest: route, iterations_used, total_tokens, converged, cost_anomaly, model_id, started_at/completed_at, full error_message. Reads ingestStore.")
        Component(providerselector, "ProviderSelector", "provider/ProviderSelector.tsx", "Header slot dropdown (F17-UI / ADR-0018 §4). Collapsed: active provider label + mode chip. Expanded: scope toggle (Vault/Global) + sorted provider list with capability labels. One-click select → POST /provider/config. INVARIANT I6: zero hardcoded provider_type/model_id literals; all values from GET /provider/config. Reads providerStore.")
        Component(settingspanel, "SettingsPanel", "settings/SettingsPanel.tsx", "Settings section (ADR-0018 §5). Context window select (4K–1M, F14) + 60/20/5/15 budget split display; IT/EN language toggle (F16); read-only provider list; reset button (clears localStorage). Reads settingsStore + providerStore.")
        Component(i18nmod, "i18n module", "i18n/index.ts + locales/{en,it}.json", "react-i18next init (ADR-0018 §6). Detection: localStorage(synapse.lang) → navigator.language → 'en'. Imports en.json + it.json. Every new UI string is a key (AC-F16-i18n-2). Key parity enforced by i18n-key-parity.test.ts.")
        Component(gstore, "graphStore + UI slice", "store/graphStore.ts", "I3. Selectors + shallow equality. UI slice: selectedSource, activeTab, treeCollapsed, activeSection (Section = pages|graph|ingest|settings — ADR-0018 §2). Actions: selectPage, setActiveTab, toggleGroup, setActiveSection. selectedNodeId UNCHANGED — single shared selection key for NavTree↔GraphViewer↔PreviewPanel sync.")
        Component(providerstore, "providerStore", "store/providerStore.ts", "SEPARATE from graphStore (I3). Holds provider list + activeItem + writeScope. fetchList()/setActiveProvider()/setWriteScope(). Persistence: no localStorage (server is source of truth). Active row derived client-side: vault-scoped rows > global rows sorted by created_at DESC (ADR-0018 §4).")
        Component(settingsstore, "settingsStore", "store/settingsStore.ts", "SEPARATE from graphStore (I3). contextWindowTokens (default 32K, F14) + language ('en'|'it', F16). Persists to localStorage. Reset action clears both keys.")
        Component(ingeststore, "ingestStore", "store/ingestStore.ts", "SEPARATE from graphStore (I3). runs[], total, offset, selectedRunId, loading, error. fetchFresh()/fetchMore()/startPolling(). Polling: 5s setTimeout chain, stops when no running rows (ADR-0018 §3). useIngestRunningCount() hook for NavRail badge.")
        Component(pagesclient, "pagesClient", "api/pagesClient.ts", "fetchPages(vaultId, {limit, offset}) → PageListResponse. fetchStatus() → GET /status. Typed. Separate from graph client; focused on tree data (metadata only, no body).")
        Component(ingestclient, "ingestClient", "api/ingestClient.ts", "fetchIngestRuns(vaultId, {limit, offset}) → IngestRunListResponse. triggerIngest(filePath) → POST /ingest/trigger. Typed. Used by ingestStore + IngestView.")
        Component(providerclient, "providerClient", "api/providerClient.ts", "fetchProviderConfigs() → ProviderConfigListResponse. createProviderConfig(body) → POST /provider/config. Typed. Used by providerStore.")
    }

