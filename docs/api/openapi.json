{
  "openapi": "3.1.0",
  "info": {
    "title": "Synapse",
    "description": "Self-organising wiki backend \u2014 M3 (graph live, no main-thread freeze). 4-signal knowledge graph (F4): direct\u00d73 + source-overlap\u00d74 + Adamic-Adar\u00d71.5 + type\u00d71. FA2 server-side via igraph (I2); coords persisted in Postgres; dataVersion-debounced GraphCache; GET /graph precomputed coords (ADR-0014). Pluggable inference provider (F17): Local/Ollama, API/Anthropic-compatible, CLI/claude-agent-sdk. Bounded orchestrated ingest loop (I7). Karpathy LLM Wiki pattern [K1\u2013K8].",
    "version": "0.3.0"
  },
  "paths": {
    "/status": {
      "get": {
        "summary": "Service health + data_version",
        "description": "Returns vault_id, current data_version (monotonic ingest counter), service started_at, and uptime_seconds. (AC-REST-1, AC-F16dv-3)",
        "operationId": "get_status_status_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusResponse"
                }
              }
            }
          }
        }
      }
    },
    "/pages": {
      "get": {
        "summary": "List live pages",
        "description": "Paginated list of pages where deleted_at IS NULL. Supports limit/offset. (AC-REST-2)",
        "operationId": "list_pages_pages_get",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 500,
              "minimum": 1,
              "description": "Max rows to return",
              "default": 50,
              "title": "Limit"
            },
            "description": "Max rows to return"
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "description": "Row offset for pagination",
              "default": 0,
              "title": "Offset"
            },
            "description": "Row offset for pagination"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PageListResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/pages/{page_id}": {
      "get": {
        "summary": "Get a single page by UUID",
        "description": "Returns full page metadata; 404 if unknown or deleted; 422 on invalid UUID. (AC-REST-3, AC-REST-6)",
        "operationId": "get_page_pages__page_id__get",
        "parameters": [
          {
            "name": "page_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Page Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PageResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/pages/{page_id}/position": {
      "patch": {
        "summary": "Persist a manual node drag position and pin the node",
        "description": "Updates pages.x/y and sets pages.pinned=true so the node stays at the dropped position across FR recomputes.  Also patches the live GraphCache snapshot in place so the next GET /graph HIT reflects the new position immediately. Does NOT trigger FR, does NOT bump data_version \u2014 O(1). (Feature A, I2)",
        "operationId": "patch_node_position_pages__page_id__position_patch",
        "parameters": [
          {
            "name": "page_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Page Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PatchPositionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Position updated and node pinned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PatchPositionResponse"
                }
              }
            }
          },
          "404": {
            "description": "Page not found"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/ingest/trigger": {
      "post": {
        "summary": "Manually trigger ingest of a single file",
        "description": "Synchronously ingests the file at file_path through the seam. Returns HTTP 202 with typed {task_id, status, page_id} (ADR-0006, AC-REST-4, AC-D4u). status is 'completed' or 'skipped' (I1 fast-path).",
        "operationId": "trigger_ingest_ingest_trigger_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IngestTriggerRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Ingest accepted and completed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IngestTriggerResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error (missing file_path, bad format, or file not found)"
          }
        }
      }
    },
    "/ingest/runs": {
      "get": {
        "summary": "List ingest run history",
        "description": "Returns a paginated, started_at DESC list of ingest_runs rows. Exposes the I7 cost ledger to the user (AC-BE-IR-1..5, ADR-0018 \u00a77). limit: 1..100 default 20; offset: >=0 default 0; vault_id: optional UUID filter. Column aliases: max_iter_used\u2192iterations_used, finished_at\u2192completed_at. total_cost_usd serialised as a number; frontend formats to exactly 4dp (I7).",
        "operationId": "list_ingest_runs_ingest_runs_get",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 100,
              "minimum": 1,
              "description": "Max rows to return (1..100); 422 on out-of-range (AC-BE-IR-2)",
              "default": 20,
              "title": "Limit"
            },
            "description": "Max rows to return (1..100); 422 on out-of-range (AC-BE-IR-2)"
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "description": "Row offset for pagination (>=0); 422 on negative (AC-BE-IR-2)",
              "default": 0,
              "title": "Offset"
            },
            "description": "Row offset for pagination (>=0); 422 on negative (AC-BE-IR-2)"
          },
          {
            "name": "vault_id",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Optional vault_id filter; omit to list all vaults (AC-BE-IR-2)",
              "title": "Vault Id"
            },
            "description": "Optional vault_id filter; omit to list all vaults (AC-BE-IR-2)"
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated ingest run list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IngestRunListResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error (limit out of 1..100 or offset < 0)"
          }
        }
      }
    },
    "/provider/config": {
      "get": {
        "summary": "List provider_config rows",
        "description": "Returns all raw provider_config rows. No API key field is stored or returned (\u00a712). (F17, AC-F17-6)",
        "operationId": "list_provider_configs_provider_config_get",
        "parameters": [
          {
            "name": "scope",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Filter by scope (global|vault|operation)",
              "title": "Scope"
            },
            "description": "Filter by scope (global|vault|operation)"
          },
          {
            "name": "vault_id",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Filter by vault_id",
              "title": "Vault Id"
            },
            "description": "Filter by vault_id"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProviderConfigListResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create or update a provider_config row",
        "description": "Create a new provider_config row. provider_type must be one of: local | api | cli. NO api_key field is accepted or stored \u2014 keys are env-only (\u00a712). (F17, ADR-0008)",
        "operationId": "create_provider_config_provider_config_post",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProviderConfigCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Row created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProviderConfigResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error (invalid provider_type, scope, or operation)"
          }
        }
      }
    },
    "/provider/config/{config_id}": {
      "delete": {
        "summary": "Delete a provider_config row by UUID",
        "description": "Hard-delete the provider_config row with the given id. (F17)",
        "operationId": "delete_provider_config_provider_config__config_id__delete",
        "parameters": [
          {
            "name": "config_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Config Id"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Row deleted"
          },
          "404": {
            "description": "Row not found"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/graph": {
      "get": {
        "summary": "Precomputed knowledge graph (nodes + edges with FA2 coordinates)",
        "description": "Returns the precomputed graph with FA2 layout coordinates (I2, F4, ADR-0014). HIT (X-Graph-Cache: hit): pure read from persisted coords + edges \u2014 no FA2. MISS (X-Graph-Cache: miss): one inline synchronous recompute, then return. Synchronous 200 \u2014 never 202 (AQ-v0.3-3). A second request at the same data_version is always a HIT (G2).",
        "operationId": "get_graph_graph_get",
        "responses": {
          "200": {
            "description": "Graph payload with precomputed coords",
            "headers": {
              "X-Graph-Cache": {
                "description": "hit|miss \u2014 mirrors the cached field (ADR-0014 \u00a75)",
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GraphResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "GraphEdgeResponse": {
        "properties": {
          "source": {
            "type": "string",
            "title": "Source"
          },
          "target": {
            "type": "string",
            "title": "Target"
          },
          "weight": {
            "type": "number",
            "title": "Weight"
          },
          "kind": {
            "type": "string",
            "title": "Kind",
            "description": "Structural edge kind: \"link\" (direct wikilink) | \"source\" (shared provenance). ADR-0016 \u00a74",
            "default": "link"
          }
        },
        "type": "object",
        "required": [
          "source",
          "target",
          "weight"
        ],
        "title": "GraphEdgeResponse",
        "description": "One graph edge in the GET /graph response (ADR-0014 \u00a76, AC-F4-3, ADR-0016 \u00a74).\n\nsource/target are page-id strings (UUID). Undirected \u2014 emitted once per pair.\nkind: structural edge discriminator \u2014 \"link\" (wikilink exists) or \"source\"\n      (shared-source provenance only). ADR-0016 \u00a74."
      },
      "GraphNodeResponse": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "title": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Title"
          },
          "type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Type"
          },
          "x": {
            "type": "number",
            "title": "X"
          },
          "y": {
            "type": "number",
            "title": "Y"
          },
          "size": {
            "type": "number",
            "title": "Size",
            "description": "BASE + GROWTH\u00b7sqrt(structural_degree); BASE=1.0, GROWTH=2.5 (ADR-0016 \u00a72)",
            "default": 1.0
          },
          "degree": {
            "type": "integer",
            "title": "Degree",
            "description": "Structural degree: count of distinct incident structural edges (direct-link or shared-source); drives size (ADR-0016 \u00a72/\u00a74)",
            "default": 0
          }
        },
        "type": "object",
        "required": [
          "id",
          "title",
          "type",
          "x",
          "y"
        ],
        "title": "GraphNodeResponse",
        "description": "One graph node in the GET /graph response (ADR-0014 \u00a76, AC-F4-3, ADR-0016 \u00a74).\n\nRequired: id, title, type, x, y.\nOptional rendering hints (derived server-side): size, degree.",
        "example": {
          "degree": 3,
          "id": "00000000-0000-0000-0000-000000000001",
          "size": 2.1,
          "title": "Alpha",
          "type": "entity",
          "x": 1.23,
          "y": -0.45
        }
      },
      "GraphResponse": {
        "properties": {
          "nodes": {
            "items": {
              "$ref": "#/components/schemas/GraphNodeResponse"
            },
            "type": "array",
            "title": "Nodes"
          },
          "edges": {
            "items": {
              "$ref": "#/components/schemas/GraphEdgeResponse"
            },
            "type": "array",
            "title": "Edges"
          },
          "data_version": {
            "type": "integer",
            "title": "Data Version"
          },
          "cached": {
            "type": "boolean",
            "title": "Cached"
          }
        },
        "type": "object",
        "required": [
          "nodes",
          "edges",
          "data_version",
          "cached"
        ],
        "title": "GraphResponse",
        "description": "GET /graph response payload (ADR-0014 \u00a76, AC-F4-3, AC-D4v3-1).\n\ncached: true on a HIT (no FA2 this request), false on a MISS (FA2 ran inline).\nHeader X-Graph-Cache: hit|miss mirrors cached (ADR-0014 \u00a75).",
        "example": {
          "cached": true,
          "data_version": 7,
          "edges": [
            {
              "kind": "link",
              "source": "00000000-0000-0000-0000-000000000001",
              "target": "00000000-0000-0000-0000-000000000002",
              "weight": 11.0
            }
          ],
          "nodes": [
            {
              "degree": 3,
              "id": "00000000-0000-0000-0000-000000000001",
              "size": 2.1,
              "title": "Alpha",
              "type": "entity",
              "x": 1.23,
              "y": -0.45
            }
          ]
        }
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "IngestRunListResponse": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/IngestRunResponse"
            },
            "type": "array",
            "title": "Items"
          },
          "total": {
            "type": "integer",
            "title": "Total"
          },
          "limit": {
            "type": "integer",
            "title": "Limit"
          },
          "offset": {
            "type": "integer",
            "title": "Offset"
          }
        },
        "type": "object",
        "required": [
          "items",
          "total",
          "limit",
          "offset"
        ],
        "title": "IngestRunListResponse",
        "description": "Paginated list response for GET /ingest/runs (ADR-0018 \u00a77, AC-BE-IR-1).\nOrdered started_at DESC (AC-BE-IR-3)."
      },
      "IngestRunResponse": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "vault_id": {
            "type": "string",
            "title": "Vault Id"
          },
          "status": {
            "type": "string",
            "title": "Status",
            "description": "running | completed | failed | converged_false (ADR-0018 \u00a77)"
          },
          "provider_type": {
            "type": "string",
            "title": "Provider Type",
            "description": "local | api | cli"
          },
          "pages_created": {
            "type": "integer",
            "title": "Pages Created",
            "description": "Wiki pages persisted during this run"
          },
          "iterations_used": {
            "type": "integer",
            "title": "Iterations Used",
            "description": "Iterations consumed (aliases max_iter_used; 0 for delegated)"
          },
          "total_cost_usd": {
            "type": "number",
            "title": "Total Cost Usd",
            "description": "Total cost in USD; 0.0 for local/cli; serialised as number (I7)"
          },
          "started_at": {
            "type": "string",
            "format": "date-time",
            "title": "Started At"
          },
          "completed_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Completed At",
            "description": "Run finish time (aliases finished_at); null for running rows"
          },
          "error_message": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Message",
            "description": "Error detail for failed runs; null otherwise"
          }
        },
        "type": "object",
        "required": [
          "id",
          "vault_id",
          "status",
          "provider_type",
          "pages_created",
          "iterations_used",
          "total_cost_usd",
          "started_at",
          "completed_at",
          "error_message"
        ],
        "title": "IngestRunResponse",
        "description": "API response shape for one ingest_runs row (ADR-0018 \u00a77, AC-BE-IR-1).\n\nColumn aliases (no DB rename \u2014 ADR-0018 \u00a77 decision):\n  max_iter_used  \u2192 iterations_used\n  finished_at    \u2192 completed_at\ntotal_cost_usd serialised as a float; frontend formats to exactly 4dp (I7).",
        "example": {
          "completed_at": "2026-06-28T10:00:05Z",
          "id": "00000000-0000-0000-0000-000000000001",
          "iterations_used": 2,
          "pages_created": 3,
          "provider_type": "api",
          "started_at": "2026-06-28T10:00:00Z",
          "status": "completed",
          "total_cost_usd": 0.0042,
          "vault_id": "default"
        }
      },
      "IngestTriggerRequest": {
        "properties": {
          "file_path": {
            "type": "string",
            "title": "File Path",
            "description": "Relative path under vault/raw/sources/"
          }
        },
        "type": "object",
        "required": [
          "file_path"
        ],
        "title": "IngestTriggerRequest"
      },
      "IngestTriggerResponse": {
        "properties": {
          "task_id": {
            "anyOf": [
              {
                "type": "string",
                "format": "uuid"
              },
              {
                "type": "null"
              }
            ],
            "title": "Task Id",
            "description": "Async task UUID (None in v0.2 synchronous mode; filled in v0.3+)"
          },
          "status": {
            "type": "string",
            "title": "Status",
            "description": "\"completed\" or \"skipped\" (I1 mtime/hash fast-path)"
          },
          "page_id": {
            "type": "string",
            "format": "uuid",
            "title": "Page Id",
            "description": "UUID of the ingested page row"
          }
        },
        "type": "object",
        "required": [
          "status",
          "page_id"
        ],
        "title": "IngestTriggerResponse",
        "description": "Typed 202 body for POST /ingest/trigger (AC-D4u \u2014 task_id appears in OpenAPI schema).\n\ntask_id is None in v0.2 (synchronous path); v0.3 fills it with a real async task UUID.\nstatus: \"completed\" | \"skipped\" (I1 fast-path) | \"queued\"/\"running\" (async, v0.3+).",
        "example": {
          "page_id": "00000000-0000-0000-0000-000000000001",
          "status": "completed"
        }
      },
      "PageListResponse": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/PageResponse"
            },
            "type": "array",
            "title": "Items"
          },
          "total": {
            "type": "integer",
            "title": "Total"
          },
          "limit": {
            "type": "integer",
            "title": "Limit"
          },
          "offset": {
            "type": "integer",
            "title": "Offset"
          }
        },
        "type": "object",
        "required": [
          "items",
          "total",
          "limit",
          "offset"
        ],
        "title": "PageListResponse"
      },
      "PageResponse": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "vault_id": {
            "type": "string",
            "title": "Vault Id"
          },
          "file_path": {
            "type": "string",
            "title": "File Path"
          },
          "title": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Title"
          },
