sequenceDiagram
    %% K2 Lint-fix loop — the third Karpathy operation (Ingest · Query · Lint) / ADR-0037
    %% Must show: deterministic + semantic findings, bounded loop (I7), and the HUMAN GATE.

    participant Client as Web UI / API Client
    participant API as FastAPI (/lint/*)
    participant DB as Postgres
    participant Lint as run_lint_scan
    participant Graph as pages/links read (deterministic, I1)
    participant Provider as InferenceProvider (I6)
    participant Enrich as enrich_wikilinks seam (I1/I5)
    participant Gen as lazy-generation seam (ADR-0034 §5)

    %% ── Scan: produces FINDINGS only — never auto-fixes ─────────────────────
    Client->>API: POST /lint/scan {vault_id, max_iter, token_budget}
    API->>DB: INSERT lint_runs (status=running, bounds FROZEN — I7)
    API->>Lint: run_lint_scan(vault_id, max_iter, token_budget)

    %% ── Step 1: Deterministic structural check (no provider call) ────────────
    Lint->>Graph: SELECT pages + links (in-degree 0 → orphan-page)
    Graph-->>Lint: orphan FindingDTO[]  (flag-only)

    %% ── Step 2: Bounded semantic loop (for n in range(1, max_iter+1)) ────────
    Lint->>Lint: resolve_provider_config("ingest", vault_id)  [I6 — no hardcode]
    loop for n in range(1, max_iter+1)  [HARD CAP — I7, ADR-0037 §4]
        Lint->>Lint: Budget gate: if tokens >= token_budget → break (under-spend)
        Lint->>Provider: chat(semantic_lint_prompt, already_found)  [≤1 call/round]
        Provider-->>Lint: {"findings":[missing-xref|contradiction|stale-claim|missing-page]}
        Lint->>Lint: de-dup vs already_found; if round adds nothing new → break
    end

    %% ── Step 3: merge + cap at LINT_MAX_FINDINGS; persist (NO data_version bump) ──
    Lint->>DB: INSERT lint_findings rows (status=open)  [human gate — no apply]
    Lint->>DB: UPDATE lint_runs SET status=completed, total_cost_usd, completed_at  [finally]
    Lint->>Lint: if total_cost_usd > $1.00 → WARNING anomaly log (I7)
    API-->>Client: 200 {run, findings[]}

    %% ── THE HUMAN GATE: apply is a SEPARATE, explicit action ────────────────
    Note over Client,Gen: Findings are PROPOSALS. Nothing is fixed until the human applies.

    Client->>API: POST /lint/findings/{id}/apply
    API->>DB: SELECT lint_findings (404 if absent; 409 if not 'open')

    alt category in {orphan-page, contradiction, stale-claim}  [FLAG-ONLY]
        API->>DB: UPDATE lint_findings SET status=applied, resolution_note  [no edit, no bump]
    else category == missing-xref
        API->>Enrich: enrich_wikilinks([referencing_page], vault_id)  [adds [[link]] to body, I5]
        Enrich->>DB: reindex edited page + bump data_version ONCE (I1)
        API->>DB: UPDATE lint_findings SET status=applied, resolution_note
    else category == missing-page
        API->>Gen: _run_generation(...) → write_wiki_page(...)  [bounded loop, one bump, I1]
        Gen->>DB: persist page + bump data_version ONCE
        API->>DB: UPDATE lint_findings SET status=applied, resolution_note
    end
    API-->>Client: 200 LintFindingResponse {status=applied}

    %% ── Dismiss: status change only ─────────────────────────────────────────
    Client->>API: POST /lint/findings/{id}/dismiss
    API->>DB: UPDATE lint_findings SET status=dismissed, reviewed_at=now()
    API-->>Client: 200 LintFindingResponse {status=dismissed}
