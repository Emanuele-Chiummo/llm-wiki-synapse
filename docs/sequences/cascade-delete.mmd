%% <!-- Generated: v0.5 sprint 5 Phase 4 | 2026-06-29 | Updated: DEFECT-F13-002 fix — raw-split wikilink rewrite -->
sequenceDiagram
    %% Cascade deletion — F13 / ADR-0026
    %% AC-D3-CD-1: must show DELETE → 3-method match → soft-delete → Qdrant delete →
    %% dead-wikilink cleanup → remove index.md entry → bump data_version → warnings.
    %% Shared-entity warning path shown as an explicit note/branch.
    %% INVARIANTS: I1 (targeted edits, no rescan, one data_version bump) · I5 (Obsidian-valid)
    %% · I2 (debounced FA2 — never inline) · I7 (single pass, no loop, no inference).

    participant Client as Web UI / API Client
    participant API as FastAPI (/pages/{id})
    participant CD as cascade_delete (ops/cascade_delete.py)
    participant DB as Postgres (pages/links/edges)
    participant Qdrant as Qdrant
    participant Wiki as vault/wiki/*.md (targeted writes, I1/I5)
    participant Raw as vault/raw/sources/ file
    participant Cache as GraphCache (I2 — debounced, no inline FA2)

    %% ── DRY-RUN / PREVIEW (mandatory — deletes user data) ────────────────────
    Client->>API: POST /pages/{id}/cascade-delete/preview
    API->>CD: plan_cascade_delete(page_id)  (READ-ONLY)
    Note over CD,DB: NO mutation: no soft-delete, no Qdrant delete,<br/>no file write, no data_version bump
    CD->>DB: locate target page (404 if missing/soft-deleted)
    CD-->>API: CascadePlan {will_delete, will_preserve_with_pruned_source,<br/>wikilinks_to_rewrite, shared_entity_warnings}
    API-->>Client: 200 CascadePlan  (modal shows warnings BEFORE any action, AC-F13-6a)

    %% ── APPLY (single pass — not a loop, I7) ─────────────────────────────────
    Client->>API: DELETE /pages/{id}   (on user confirm)
    API->>CD: cascade_delete(page_id)
    CD->>DB: locate target page (404 if already soft-deleted, AC-F13-5c)

    %% ── 3-method reference match (AC-F13-2) — no vault rescan (I1) ───────────
    Note over CD,DB: 3-METHOD MATCH (logged per reference):<br/>(a) exact links.target_page_id / target_title<br/>(b) slug-normalised links.target_title<br/>(c) fulltext fallback over live wiki/ (bounded, §3.1)
    CD->>DB: SELECT links WHERE target_page_id=:id OR target_title=:T   (back-reference index)
    DB-->>CD: referencing wiki pages (source_page_id, file_path)

    %% ── Preserve shared entities (AC-F13-2 / AC-F13-3) ───────────────────────
    Note over CD: PARTITION sources[]:<br/>empty after removing X → will_delete<br/>still non-empty → preserve + prune one sources[] entry
    opt source-overlap pages (edges, kind='source')
        CD->>DB: read edges (shared-entity check — never FA2, I2)
        Note over CD: WARN, never block — deletion proceeds (AC-F13-3)
    end

    %% ── Data plane: soft-delete + Qdrant (mirrors delete_file, ADR-0005) ─────
    CD->>DB: UPDATE pages SET deleted_at=now() for each will_delete (soft-delete)
    CD->>Qdrant: delete_point(page_id) for each deleted page (hard-delete)

    %% ── Dead-wikilink cleanup — frontmatter-safe, targeted (I5/I1) ───────────
    loop each referencing wiki file (ONLY these — AC-F13-4a/b)
        CD->>Wiki: raw ---split → rewrite [[T]]→T in BODY only → frontmatter block byte-for-byte (I5, DEFECT-F13-002 fix)
        CD->>DB: re-persist_links(file) ; set links.dangling=True residuals (step 7)
    end

    %% ── Preserve branch: prune sources[] (key-order-preserving) ─────────────
    opt preserve+prune pages
        CD->>Wiki: frontmatter.loads → remove X from sources[] → frontmatter.dumps(sort_keys=False)
        CD->>DB: UPDATE pages.sources JSONB
    end

    %% ── index.md regenerated from LIVE pages (K3 — entry auto-removed, I1) ───
    CD->>DB: read live pages (deleted_at IS NULL)
    CD->>Wiki: update_index() once → index.md (deleted entry gone automatically)

    %% ── No restart resurrection (AQ-v0.5-5) ──────────────────────────────────
    CD->>Raw: delete raw/sources/X file (watcher sees DELETE, not CREATE on restart)
    Note over Raw,DB: watcher ignores deleted_at IS NOT NULL rows → no resurrection

    %% ── data_version bumped EXACTLY ONCE → debounced FA2 (I2/AC-F13-4c/d) ────
    CD->>DB: bump_version()  (+1 — exactly once, regardless of files touched)
    CD->>Cache: notify_bump(new_version)
    Note over Cache: debounced recompute fires later — NO inline FA2 (I2)

    CD-->>API: CascadeResult {deleted_page_id, wikilinks_cleaned,<br/>index_entry_removed, shared_entity_warnings}
    API-->>Client: 200 CascadeResult
