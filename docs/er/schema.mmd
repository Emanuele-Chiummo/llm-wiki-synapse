<!-- Generated: v0.5-ADR-0033 | 2026-06-30 — ADR-0033: vault_state +mcp_access_token_hash +mcp_allow_without_token (migration 0012); ADR-0032: +remote_mcp_enabled (migration 0011); ADR-0025: review_items; ADR-0024: deep_research_runs/sources -->
erDiagram

    CONVERSATIONS {
        uuid id PK "Conversation identity"
        string vault_id "Logical vault scope (matches pages/edges pattern); from VAULT_ID env var"
        string title "User-set or first-prompt-derived title; NULL until set (ADR-0019 §2.5)"
        timestamptz created_at "Row creation time"
        timestamptz updated_at "Bumped on each chat turn; drives last-active-conversation restore (AC-F6-1)"
        timestamptz deleted_at "NULL = live; set = soft-deleted (ADR-0005 / ADR-0019 §2.5)"
    }

    IMPORT_SCHEDULES {
        uuid id PK "Row identity"
        string vault_id "Logical vault identifier — one schedule row per vault (UNIQUE)"
        boolean enabled "Scheduler is a no-op while false (ADR-0020 §4.1)"
        string source_dir "Container-visible absolute path to scan (e.g. /import). NULL until set by the user. Must be mounted into the container (ADR-0020 §7)."
        string frequency "Scan interval enum: '15m' | '1h' | '6h' | 'daily' (I7 — bounded, ADR-0020 §4.1)"
        timestamptz last_run_at "Timestamp of the last completed scan; NULL if never run"
        string last_status "Outcome of the last scan: 'ok' | 'error' | 'running' | 'skipped_disabled' | 'dir_missing' | NULL (never run)"
        int last_imported_count "Number of files copied (new/changed) during the last scan (ADR-0020 §4.3)"
        string last_error "Human-readable error from the last failed scan; NULL on success"
        timestamptz created_at "Row creation time"
        timestamptz updated_at "Updated on every PUT or scan completion"
    }

    LINT_RUNS {
        uuid id PK "Run identity"
        string vault_id "Scope — string, no vaults table (AQ-v0.5-6, ADR-0037 §3.1)"
        string status "running | completed | error. Defaults 'running'; terminal write always in finally (never left 'running' on fall-through — ADR-0037 §4)."
        int max_iter "Iteration cap FROZEN at INSERT from POST body → LINT_MAX_ITER default (I7)"
        int token_budget "Token budget FROZEN at INSERT from POST body → LINT_TOKEN_BUDGET default (I7)"
        int iterations_used "Semantic rounds consumed (0..max_iter); 0 for deterministic-only scans"
        int findings_count "Number of findings emitted by this scan (capped at LINT_MAX_FINDINGS)"
        decimal total_cost_usd "I7 cost ledger; 0.0000 for local/cli (ADR-0009); $1 anomaly threshold"
        timestamptz started_at "Run start time"
        timestamptz completed_at "NULL while running; set in finally block (mirrors deep_research_runs)"
        string error_message "Populated only on status='error'; NULL otherwise"
        timestamptz created_at "Row creation time (mirrors deep_research_runs/review_items)"
    }

    PAGES {
        uuid id PK "Page identity; also the Qdrant point id (ADR-0002)"
        string vault_id "Logical vault identifier — from VAULT_ID env var"
        string file_path "Relative path under vault/raw/sources/; join key to filesystem"
        string title "YAML frontmatter 'title'; NULL if absent (K6, AC-K6-2/3)"
        string type "YAML frontmatter 'type'; NULL if absent (K6)"
        jsonb sources "YAML frontmatter 'sources[]' as JSONB array; NULL if absent (K6)"
        string content_hash "sha256 hex of raw file bytes — authoritative change signal (ADR-0001)"
        int source_mtime_ns "st_mtime_ns at last confirmed index — cheap fast-path gate (ADR-0001)"
        uuid qdrant_point_id "Qdrant point id == pages.id; explicit to allow deliberate divergence later"
        double x "FR x-coordinate (DOUBLE PRECISION); NULL until first layout (ADR-0013)"
        double y "FR y-coordinate (DOUBLE PRECISION); NULL until first layout (ADR-0013)"
        boolean pinned "True when the user manually positioned this node via PATCH /pages/{id}/position. Engine preserves pinned coords across FR recomputes (Feature A)."
        timestamptz deleted_at "NULL = live; set = soft-deleted (ADR-0005); Qdrant point hard-deleted"
        timestamptz created_at "Row creation time"
        timestamptz updated_at "Updated on every upsert (AC-WATCH-3)"
    }

    PROVIDER_CONFIG {
        uuid id PK "Row identity"
        string scope "global | vault | operation (ADR-0008 §2)"
        string operation "ingest | chat | lint; NULL unless scope='operation' (AQ-v0.2-5)"
        string vault_id "NULL at global scope; required at vault/operation scope"
        string provider_type "local | api | cli — selects the InferenceProvider backend (I6)"
        string model_id "Model name (e.g. claude-sonnet-4-6); value lives ONLY in DB rows (AC-F17-8)"
        string base_url "OpenAI-compatible endpoint for ApiProvider; NULL for Anthropic/local default"
        int max_iter "Orchestrated-loop iteration cap (I7, ADR-0009)"
        int token_budget "Loop token budget (I7); 60000 orchestrated / 100000 cli (ADR-0009)"
        boolean is_fallback "Marks the single fallback row for a scope (ADR-0009 §fallback)"
        timestamptz created_at "Row creation time"
        timestamptz updated_at "Updated on every change"
    }

    VAULT_STATE {
        uuid id PK "Row identity"
        string vault_id "One row per vault; from VAULT_ID env var"
        int data_version "Monotonic; +1 per successful upsert ingest (AC-F16dv-2/4); FA2 debounce signal"
        boolean remote_mcp_enabled "Runtime toggle for the remote (HTTP) MCP surface (ADR-0032 §2.1). Default OFF; requires MCP_AUTH_TOKEN to be set before enabling. Persisted here; read into RemoteMcpFlag cache in main.py at startup."
        string mcp_access_token_hash "Salted PBKDF2-HMAC-SHA256 hash of the UI-set MCP access token (ADR-0033 §2.1). Format: pbkdf2_sha256$<iters>$<salt_b64>$<hash_b64>. NULL = no UI token; env MCP_AUTH_TOKEN is the bootstrap fallback. NEVER stores plaintext. Token shown once at generation time (one-time reveal). DB-hash takes precedence over env bootstrap when set. Migration 0012."
        boolean mcp_allow_without_token "When ON: PRIVATE sources (loopback/CGNAT/RFC1918/link-local/ULA) may reach /mcp/server without a bearer token (ADR-0033 §2.3). PUBLIC sources (Cloudflare tunnel — CF-Connecting-IP/CF-Ray) are NEVER exempted regardless of this flag (fail-safe by construction). Default false — fail-closed. Migration 0012."
        timestamptz updated_at "Last bump time"
    }

    DEEP_RESEARCH_RUNS {
        uuid id PK "Run identity"
        string vault_id "Scope — string, no vaults table (AQ-v0.5-6, ADR-0024 §7.1)"
        string topic "The research topic provided by the caller"
        string status "running | converged | max_iter_reached | budget_exhausted | error. Defaults 'running'; terminal write always in finally (Do-NOT #7, ADR-0024 §3.2)"
        int max_iter "Iteration cap FROZEN at INSERT from POST body → env default (AQ-v0.5-4)"
        int token_budget "Token budget FROZEN at INSERT (AQ-v0.5-4, I7)"
        int iterations_used "Rounds consumed (1..max_iter); 0 until first round completes"
        jsonb queries_used "Array of every query issued, per round (AC-F10-4c)"
        int sources_fetched "Count of fetched candidate sources across all iterations"
        boolean converged "True iff status == 'converged' (audit convenience, ADR-0024 §7.1)"
        decimal total_cost_usd "I7 cost ledger; 0.0000 for local/cli (ADR-0009); $1 anomaly threshold"
        string synthesis_text "The synthesized markdown; NULL until step 5 completes (AC-F10-4c)"
        uuid synthesis_page_id FK "FK → pages.id created by the re-entrant ingest_file; NULL until done"
        timestamptz started_at "Run start time"
        timestamptz completed_at "NULL while running; set in finally block (mirrors ingest_runs alias rule)"
        string error_message "Populated only on status='error'; NULL otherwise"
    }

    EDGES {
        uuid id PK "Row identity"
        string vault_id "Scope edges per vault (matches pages/vault_state pattern)"
        uuid source_page_id FK "Unordered pair stored canonically (smaller UUID first by string sort). FK → pages.id (ADR-0012 / AQ-5)"
        uuid target_page_id FK "FK → pages.id; target of the undirected pair (ADR-0012)"
        double weight "Additive 4-signal weight > 0 (ADR-0012): 3·direct + 4·source_overlap + 1.5·adamic_adar + 1·same_type"
        jsonb signals "Per-signal breakdown {"direct","source","aa","type"} for audit (AC-F4-1(e))"
        string kind "Structural edge discriminator: "link" (direct wikilink present) | "source" (shared provenance only). ADR-0016 §4. NULL for rows written before migration 0004 (treated as link)."
        timestamptz created_at "Row creation time (set on each recompute batch)"
    }

    INGEST_RUNS {
        uuid id PK "Row identity"
        string vault_id "Vault this run belongs to"
        uuid page_id FK "Originating source page; NULL on a pre-write failure"
        string provider_name "Provider class name (e.g. OllamaProvider) — AUDIT ONLY, never routed on (I6)"
        string provider_type "local | api | cli (audit)"
        string model_id "Resolved model used (audit)"
        string route "orchestrated | delegated (capability-aware routing outcome)"
        int max_iter_used "Iterations actually consumed (1..max_iter); 0 for delegated"
        int total_tokens "input+output tokens across all iterations (I7)"
        decimal total_cost_usd "0.0000 for local/cli (ADR-0009); logged per run (I7)"
        boolean converged "True if a valid batch was produced within max_iter"
        boolean cost_anomaly "True if total_cost_usd > 1.00 (ADR-0009 §3)"
        timestamptz started_at "Run start time"
        timestamptz finished_at "Run finish time"
        string status "Run lifecycle state: running | completed | failed | converged_false. Backfilled from converged for historical rows (ADR-0018 §7)."
        int pages_created "Number of wiki pages persisted during this run. 0 for historical rows; set by orchestrator on new runs (ADR-0018 §7)."
        string error_message "Human-readable error description for failed runs; NULL for completed/running/converged_false rows (ADR-0018 §7)."
    }

    LINKS {
        uuid id PK "Row identity"
        uuid source_page_id FK "FK → pages.id; the page that contains the wikilink (K5)"
        string target_title "The [[Target]] title string as written (K5)"
        uuid target_page_id FK "Resolved FK → pages.id; NULL while the target page does not exist (K5, v0.3)"
        string alias "The |alias part of [[Target|alias]], if present (K5)"
        boolean dangling "True when target_page_id is unresolved (AC-K5-5); warn-not-error path"
        timestamptz created_at "Row creation time"
    }

    LINT_FINDINGS {
        uuid id PK "Finding identity"
        uuid lint_run_id FK "FK → lint_runs.id (ON DELETE CASCADE)"
        string vault_id "Denormalised vault scope (matches the run's vault; AQ-v0.5-6)"
        string category "Finding category (ADR-0037 §3.1 enum-by-convention, no DB CHECK): orphan-page | missing-xref | contradiction | stale-claim | missing-page."
        string severity "info | warning | error (advisory; display ordering). ADR-0037 §3.1."
        uuid target_page_id FK "FK → pages.id; the page the finding is about. NULL when none applies (e.g. a missing-page finding about a not-yet-existing title). ADR-0037 §3.1."
        string target_title "The page title the finding concerns (missing-page: title to create; missing-xref: the existing page that should be linked). ADR-0037 §3.1."
        string description "Human-readable 'what is wrong' (ADR-0037 §3.1)."
        string proposed_action "Human-readable description of the fix apply_lint_fix would attempt. NULL for flag-only findings (contradiction/stale-claim/orphan). ADR-0037 §3.1/§5."
        string status "open | applied | dismissed. Defaults 'open' (ADR-0037 §3.1)."
        string resolution_note "How the finding was resolved (apply outcome / dismiss reason). NULL while open."
        timestamptz created_at "Row creation time"
        timestamptz reviewed_at "Set on apply/dismiss; NULL while open."
    }

    MESSAGES {
        uuid id PK "Message identity"
        uuid conversation_id FK "FK → conversations.id (ADR-0019 §2.5)"
        string role "'user' | 'assistant' | 'system' (ADR-0019 §2.5)"
        string content "RAW message content, incl. literal <think>…</think> un-mutated (AC-F7-2)"
        jsonb citations "RESERVED for M5 [n] citations; always [] in M4 (ADR-0019 §2.3)"
        string provider_type "Backend that produced an assistant msg (audit); NULL for user/system"
        string model_id "Resolved model that produced an assistant msg (audit); NULL otherwise"
        int input_tokens "Prompt tokens for an assistant turn (I7 persistent cost record)"
        int output_tokens "Completion tokens for an assistant turn (I7)"
        decimal total_cost_usd "0.0000 for local/cli (ADR-0009); logged + returned in done event (I7)"
        timestamptz created_at "Row creation time; messages ordered created_at ASC (ADR-0019 §2.5)"
    }

    DEEP_RESEARCH_SOURCES {
        uuid id PK "Row identity"
        uuid run_id FK "FK → deep_research_runs.id (ON DELETE CASCADE)"
        string url "The fetched source URL (from SearXNG hit)"
        string title "Hit title from SearXNG; may be URL if no title available"
        string fetched_content_md "Extracted markdown (capped at DEEP_RESEARCH_FETCH_MAX_CHARS); NULL on fetch failure (ADR-0024 §4 / Do-NOT #9)"
        decimal relevance_score "Optional model/heuristic relevance; NULL in Phase 2 (ADR-0024 §11)"
        int iteration "Which round produced this source (1..max_iter); audit trail"
        timestamptz created_at "Row creation time"
    }

    REVIEW_ITEMS {
        uuid id PK "Row identity"
        string vault_id "Logical vault identifier — existing String (no FK, no vaults table). AQ-v0.5-6; ADR-0034 §3.1"
        string item_type "Proposal type (ADR-0034 §3.1 enum-by-convention, no DB CHECK): missing-page | suggestion | contradiction | duplicate | confirm. Old values (new_page/update_page/deep_research_candidate) are obsolete after migration 0013 left-shifts them to skipped."
        string status "Lifecycle (ADR-0034 §3.1): pending | created | skipped | deep_researched | auto_resolved. Defaults 'pending'. (approved is gone; Create produces created.)"
        uuid page_id FK "FK → pages.id; the review TARGET: existing page a contradiction/duplicate conflicts with, or source-context page for missing-page/suggestion. NULL when none applies. (ADR-0034 §3.1 — re-documented column)"
        uuid source_page_id FK "FK → pages.id; the page WHOSE INGEST produced this proposal (provenance). Distinct from page_id (the conflicting/target page). Lets the UI show 'proposed while ingesting X'. ADR-0034 §3.1 ADD."
        string proposed_title "The title the LLM proposes to create (required for missing-page; advisory for others). Drives the lazy skeleton (ADR-0034 §5.2) and rule-based sweep title match (§6.2). ADR-0034 §3.1 ADD."
        string proposed_page_type "Inferred PageType for the lazy skeleton: entity|concept|source|synthesis|comparison. NULL → heuristic applied at Create time (ADR-0034 §5.2). source is never a valid Create target. ADR-0034 §3.1 ADD."
        string proposed_dir "Target wiki/ subdir derived from proposed_page_type (DISPLAY ONLY). Recomputed from the final type at Create time — never trusted blindly (ADR-0034 §5.2). ADR-0034 §3.1 ADD."
        string rationale "Short human-readable 'why this matters' (ADR-0034 §3.1 ADD). Replaces the old per-page follow-up questions (pre_generated_query is DROPPED). For suggestion: the gap/follow-up; for contradiction: the conflict description; for confirm: what needs confirming. Used as the topic hint for Deep Research."
        string resolution "How the item closed (ADR-0034 §3.1 ADD): created | skipped | researched | rule_resolved | llm_resolved. NULL while pending. Complements status (status records *what* happened; resolution records *how* it was resolved)."
        uuid created_page_id FK "FK → pages.id; the page a successful Create action produced (ADR-0034 §5). NULL while status != 'created'. Distinct from page_id and source_page_id. ADR-0034 §3.1 ADD."
        uuid deep_research_run_id FK "FK → deep_research_runs.id; set when the Deep-Research action fires (AC-F10-5). NULL while status != 'deep_researched'. Unchanged from ADR-0025."
        timestamptz created_at "Row creation time"
        timestamptz reviewed_at "Set on any terminal action (Create/Skip/Deep-Research/auto-resolve); NULL while pending."
        string reviewed_by "'web-ui' for human actions; 'auto-sweep' for the sweep (ADR-0034 §6.2/§6.3). NULL while pending."
    }
